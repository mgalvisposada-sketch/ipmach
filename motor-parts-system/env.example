# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/motor_parts_analytics"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Currency API Configuration
# API key for CurrencyFreaks (https://currencyfreaks.com) or ExchangeRate-API v6 (https://www.exchangerate-api.com)
# Free tiers: CurrencyFreaks (1,000 req/month), ExchangeRate-API v6 (1,500 req/month)
# If not provided, will use ExchangeRate.host (100 req/month, no API key required)
CURRENCY_API_KEY="your-currency-api-key"
CURRENCY_API_URL="https://api.exchangeratesapi.io"

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PDF Generation
PDF_STORAGE_PATH="./public/pdfs"

# Logging
LOG_LEVEL="info"

# Security
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-encryption-key-here"

# External Services
REDIS_URL="redis://localhost:6379"

# Deep Search Service Configuration
# URL of the Deep Search Service (standalone microservice)
DEEP_SEARCH_SERVICE_URL=http://localhost:3001
# API Key for authenticating with Deep Search Service
DEEP_SEARCH_SERVICE_API_KEY=your-shared-secret-api-key

# Costex External API Configuration
COSTEX_API_URL="https://www.ctpsales.costex.com:11443/WebServices/costex/partService/partController.php"
COSTEX_ACCESS_KEY="aaa"
COSTEX_USER_ID="WSU4529"
COSTEX_PASSWORD="dddd"
COSTEX_CUSTOMER="4529"

# OpenAI (asistente IPMach: respuestas desde el catálogo PDF)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Base vectorial del asistente IPMach (Supabase). Opcional: si no está, se usa DATABASE_URL.
# Connection string en Supabase: Project Settings → Database → Connection string (URI)
# IPMACH_VECTOR_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-xx.pooler.supabase.com:6543/postgres"

# Monitoring
SENTRY_DSN="your-sentry-dsn-here"
